{
  "expo": {
    "name": "Fuel Up",
    "slug": "fuel-up",
    "scheme": "fuelup",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#000000"
    },
    "ios": {
      "icon": "./fuelup.icon",
      "supportsTablet": true,
      "bundleIdentifier": "com.fuelup.app",
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "Fuel Up requires precise location access to function.",
        "NSLocationAlwaysAndWhenInUseUsageDescription": "Fuel Up requires precise location access to function."
      }
    }
  }
}
